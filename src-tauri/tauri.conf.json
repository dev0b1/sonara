{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sonara",
  "version": "0.1.0",
  "identifier": "com.sonara.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sonara",
        "width": 900,
        "height": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
